<Window x:Class="Практическая4_Русаков_Худайбердин.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Практическая4_Русаков_Худайбердин"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="LightGray">
            <Button Content="Страница 1" Width="120" Margin="5" 
                    Click="ButtonPage1_Click" ToolTip="Перейти к странице 1"/>
            <Button Content="Страница 2" Width="120" Margin="5" 
                    Click="ButtonPage2_Click" ToolTip="Перейти к странице 2"/>
            <Button Content="Страница 3" Width="120" Margin="5" 
                    Click="ButtonPage3_Click" ToolTip="Перейти к странице 3"/>
        </StackPanel>

        <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
